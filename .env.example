# Alpaca API Credentials
# Get these from https://app.alpaca.markets/
APCA_API_KEY_ID=your_api_key_here
APCA_API_SECRET_KEY=your_api_secret_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Keep-Alive Configuration (for cloud deployment)
# URL of your deployed Streamlit app
STREAMLIT_APP_URL=https://your-app-name.onrender.com

# Ping interval in seconds (default: 180 = 3 minutes)
KEEP_ALIVE_INTERVAL=180

# Streamlit Configuration (for docker/deployment)
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Optional: Additional environment variables
# DEBUG=true
