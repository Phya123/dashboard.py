def sentinel_ai_chat():

    from ai_core.assistant import sentinel_response

    st.divider()

    st.subheader("🤖 Sentinel AI Assistant")


    question = st.text_input(
        "💬 Ask Sentinel",
        placeholder="Ask about your portfolio, market, or app..."
    )


    if st.button("Ask Sentinel"):

        if question:

            answer = sentinel_response(
    question,
    st.session_state.get("sentinel_state")
)

            st.success(answer)
